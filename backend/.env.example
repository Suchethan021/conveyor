# Backend service configuration (copy to .env and adjust).
# DATABASE_URL points at local Docker Postgres by default.
DATABASE_URL=postgres://conveyor:conveyor@localhost:5432/conveyor?sslmode=disable
PORT=8080
WORKER_CONCURRENCY=2

# Session signing key — generate a long random value, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# GitHub OAuth app credentials (from https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback

# Where the SPA runs; used for post-login redirects.
FRONTEND_URL=http://localhost:5173

# Local-only login shortcut for testing without GitHub. Never true in prod.
ALLOW_DEV_LOGIN=true
