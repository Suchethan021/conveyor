# Root environment for docker-compose (copy to .env).
POSTGRES_USER=conveyor
POSTGRES_PASSWORD=conveyor
POSTGRES_DB=conveyor

# Session signing key (override the insecure compose default for anything real).
SESSION_SECRET=dev-only-insecure-session-secret-change-me

# GitHub OAuth app credentials. Leave blank to run without login (routes 503).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback
FRONTEND_URL=http://localhost:5173
