# Frontend build-time config. Copy to frontend/.env (gitignored).
#
# Base URL for the backend API. Leave blank to call the API at the same origin
# via the dev-server / nginx proxy (the default for local + the bundled compose).
# Set to the backend's absolute URL only when the frontend is deployed on a
# different domain than the backend (e.g. Vercel frontend + Render backend).
VITE_API_URL=
