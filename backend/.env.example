# Backend service configuration. Copy to backend/.env (gitignored) and fill in.
#
# Host is "db" (the compose service name) when run via docker compose.
# If you run the Go binary directly against a local Postgres, use "localhost".
DATABASE_URL=postgres://conveyor:conveyor@db:5432/conveyor?sslmode=disable
PORT=8080
WORKER_CONCURRENCY=2

# Session signing key — generate a long random value, e.g.:
#   openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# GitHub OAuth app credentials (from https://github.com/settings/developers).
# Leave blank to run without GitHub login (login routes return 503; use dev-login).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Callback goes through the frontend origin (nginx proxies /api to the backend),
# so the OAuth flow stays same-origin and the session cookie is set correctly.
# Compose serves the frontend on :3000; the Vite dev server uses :5173.
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Where the SPA is served; used for post-login redirects.
FRONTEND_URL=http://localhost:3000

# Local-only login shortcut for testing without GitHub. Never true in prod.
ALLOW_DEV_LOGIN=true
